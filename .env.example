# ─── SANITY CMS ───────────────────────────────────────────────────────────────
# Get these values from your Sanity project at: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token_here

# ─── SITE URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sc-metropolis25.de

# ─── EMAIL / CONTACT FORM ─────────────────────────────────────────────────────
# For contact form emails — use Resend, SendGrid, or similar
EMAIL_FROM=noreply@sc-metropolis25.de
EMAIL_TO=info@sc-metropolis25.de
RESEND_API_KEY=your_resend_api_key_here

# ─── ANALYTICS (optional) ─────────────────────────────────────────────────────
# Plausible, Umami, or Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── CLOUDINARY (optional image hosting) ─────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
